rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Lawyer verification documents — upload by owner, read by admin
    match /verifications/{uid}/{fileName} {
      allow read: if request.auth != null && (request.auth.uid == uid || isAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Consultation recordings — read by participants only
    match /recordings/{consultationId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if false; // Server-side only
    }

    function isAdmin() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
  }
}
